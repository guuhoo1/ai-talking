<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aitalking.mapper.AiKnowledgeMapper">
    <insert id="insert" parameterType="com.aitalking.model.AiKnowledge" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_knowledge (title, summary, core_code, tech_tags, scene, principle, notes, reusable, source_message_id, create_time)
        VALUES (#{title}, #{summary}, #{coreCode}, #{techTags}, #{scene}, #{principle}, #{notes}, #{reusable}, #{sourceMessageId}, #{createTime})
    </insert>

    <select id="selectById" parameterType="java.lang.Long" resultType="com.aitalking.model.AiKnowledge">
        SELECT * FROM ai_knowledge WHERE id = #{id}
    </select>

    <select id="selectAll" resultType="com.aitalking.model.AiKnowledge">
        SELECT * FROM ai_knowledge ORDER BY create_time DESC
    </select>

    <select id="selectBySourceMessageId" parameterType="java.lang.Long" resultType="com.aitalking.model.AiKnowledge">
        SELECT * FROM ai_knowledge WHERE source_message_id = #{sourceMessageId}
    </select>

    <select id="selectByTechTag" parameterType="java.lang.String" resultType="com.aitalking.model.AiKnowledge">
        SELECT * FROM ai_knowledge WHERE tech_tags LIKE CONCAT('%', #{tag}, '%') ORDER BY create_time DESC
    </select>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM ai_knowledge WHERE id = #{id}
    </delete>
</mapper>